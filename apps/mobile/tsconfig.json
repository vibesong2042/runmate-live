{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "../..",
    "paths": {
      "@runmate/shared": ["packages/shared/src/index.ts"],
      "@runmate/shared/*": ["packages/shared/src/*"]
    },
    "types": ["react", "node"],
    "noEmit": true
  },
  "include": ["App.tsx", "src/**/*.ts", "src/**/*.tsx"]
}
